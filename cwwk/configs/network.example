# Example /etc/config/network for the CWWK N305 4-port appliance.
# Replace every <PLACEHOLDER> with real values from your AWG .conf.
# Never commit the populated file with private keys.
#
# Hardware: Intel Core i3-N305 + Intel 82599ES (2× SFP+ 10G) + Intel
# i226-V (2× 2.5GbE). External 12V brick. M.2 2280 NVMe for storage,
# M.2 2230 CNVi for Wi-Fi (unused in this setup — Wi-Fi is provided
# by a separate UniFi AP downstream).
#
# Port naming on first boot is kernel/udev-dependent. Likely candidates:
#
#   eth0..eth3                  (kernel-ordered, common on OpenWrt x86)
#   enp1s0 / enp2s0 / ...       (systemd-style predictable names; less
#                                common under OpenWrt's procd, but the
#                                ixgbe + igc combo on N305 occasionally
#                                surfaces them)
#
# After the first boot, run `ip link` and `ethtool <iface>` to identify
# which physical port maps to which interface — the two SFP+ ports
# (ixgbe driver) and two 2.5G RJ45 (igc driver) can be told apart by
# `ethtool --driver` output. Then substitute the <WAN_PORT> /
# <TRUNK_PORT> placeholders below with the actual names.
#
# Suggested role assignment for the dual-WAN-on-trunk + UDR7-downstream
# scenario:
#
#   <WAN_PORT>     — one of the 2.5G RJ45 (igc) facing the ISP modem.
#                    SFP+ stays free in case a 10G uplink becomes
#                    available later; igc is plenty for residential.
#   <TRUNK_PORT>   — one of the SFP+ if there's a DAC/fiber to the
#                    UDR7-area switch; otherwise the second 2.5G RJ45.
#                    Carries VLAN-tagged sub-interfaces for downstream
#                    L2 segments (bypass/vpn/management) — see "Three
#                    traffic classes" in README.
#   remaining 2    — leave unassigned in br-lan or use for direct LAN
#                    extensions later.
#
# AWG obfuscation params use the awg_ prefix on the interface section
# (awg_jc, awg_jmin, awg_jmax, awg_s1..awg_s4, awg_h1..awg_h4, optional
# awg_i1..awg_i5). Without the prefix /lib/netifd/proto/amneziawg.sh
# silently falls back to defaults and the server drops every packet.
#
# IMPORTANT: do NOT set `option mtu '1280'` on the lan section. With a
# br-lan bridge that spans both 1500-MTU physical ports and any future
# Wi-Fi AP attachment, mixed MTUs cause DEVICE_CLAIM_FAILED on the
# bridge. Announce MTU 1280 to clients via DHCP option 26 instead —
# see configs/dhcp.

config interface 'loopback'
	option device 'lo'
	option proto 'static'
	option ipaddr '127.0.0.1'
	option netmask '255.0.0.0'

config globals 'globals'
	option ula_prefix 'fd00:abcd:1234::/48'

# br-lan spans any "local" physical ports + the trunk to the downstream
# UDR7/Flex Mini cluster. VLAN sub-interfaces of the trunk port are
# attached below as separate logical interfaces (bypass / vpn / mgmt).
config device
	option name 'br-lan'
	option type 'bridge'
	list ports '<TRUNK_PORT>'
	# Optionally append more ports (e.g. spare 2.5G or SFP+) that should
	# share the same untagged LAN segment:
	# list ports '<SPARE_PORT>'

config interface 'lan'
	option device 'br-lan'
	option proto 'static'
	option ipaddr '192.168.1.1'
	option netmask '255.255.255.0'
	option ip6assign '60'

config interface 'wan'
	option device '<WAN_PORT>'
	option proto 'dhcp'
	option metric '10'

config interface 'wan6'
	option device '<WAN_PORT>'
	option proto 'dhcpv6'
	option metric '10'

# VLAN sub-interfaces on the trunk port — optional, only needed if the
# downstream UDR7 cluster splits clients into per-VLAN segments. Each
# sub-interface gets its own DHCP server (see configs/dhcp) and its own
# subnet, and policy-routing on OpenWrt decides whether its traffic
# rides awg0 (vpn) or table 100 (bypass) by source subnet match.
#
# Uncomment and adapt VLAN IDs to match the UDR7 configuration.

# config device
# 	option name '<TRUNK_PORT>.10'
# 	option type '8021q'
# 	option ifname '<TRUNK_PORT>'
# 	option vid '10'

# config interface 'lan_vpn'
# 	option device '<TRUNK_PORT>.10'
# 	option proto 'static'
# 	option ipaddr '192.168.10.1'
# 	option netmask '255.255.255.0'

# config device
# 	option name '<TRUNK_PORT>.20'
# 	option type '8021q'
# 	option ifname '<TRUNK_PORT>'
# 	option vid '20'

# config interface 'lan_bypass'
# 	option device '<TRUNK_PORT>.20'
# 	option proto 'static'
# 	option ipaddr '192.168.20.1'
# 	option netmask '255.255.255.0'

config interface 'awg0'
	option proto 'amneziawg'
	option private_key '<CLIENT_PRIVATE_KEY>'
	option mtu '1280'
	list addresses '<10.x.x.x/32>'
	list addresses '<IPV6_ADDRESS/128>'
	# AWG v2 obfuscation parameters — copy from your [Interface] section.
	# Values that span ranges (e.g. H1 '168781656-175897653') are passed
	# as-is, the proto handler forwards them to `awg setconf` literally.
	option awg_jc '<JC>'
	option awg_jmin '<JMIN>'
	option awg_jmax '<JMAX>'
	option awg_s1 '<S1>'
	option awg_s2 '<S2>'
	option awg_s3 '<S3>'
	option awg_s4 '<S4>'
	option awg_h1 '<H1>'
	option awg_h2 '<H2>'
	option awg_h3 '<H3>'
	option awg_h4 '<H4>'
	# Uncomment if your .conf has I1..I5
	# option awg_i1 '<I1>'
	# option awg_i2 '<I2>'
	# option awg_i3 '<I3>'
	# option awg_i4 '<I4>'
	# option awg_i5 '<I5>'

config amneziawg_awg0
	option public_key '<SERVER_PUBLIC_KEY>'
	# option preshared_key '<PRESHARED_KEY>'   # if your conf has one
	option endpoint_host '<SERVER_HOSTNAME>'
	option endpoint_port '<SERVER_PORT>'
	option persistent_keepalive '30'
	option route_allowed_ips '1'
	list allowed_ips '0.0.0.0/0'
	list allowed_ips '::/0'
