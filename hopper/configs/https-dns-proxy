# /etc/config/https-dns-proxy — DoH listener on 127.0.0.1:5053.
#
# IMPORTANT: resolver_url uses an IP literal, not a hostname. Reason:
# Russian cellular operators (MegaFon at least, others likely too)
# routinely block plain UDP/53 from CGNAT clients to public DNS
# resolvers (1.1.1.1, 1.0.0.1, 8.8.8.8). Bootstrap DNS — which c-ares
# uses to resolve the resolver_url hostname over plain DNS — times out
# silently, c-ares reports "Channel is being destroyed", and the proxy
# enters a state where it accepts incoming DNS queries but discards
# them with "Query received before bootstrapping is completed". The
# proxy never logs an outbound TLS failure because TLS never gets a
# chance to start.
#
# Using `https://1.1.1.1/dns-query` skips the bootstrap-resolve step
# entirely. Cloudflare's cert covers `1.1.1.1` as a SAN, so cert
# validation works.
#
# But: this only helps when the operator passes HTTPS/443 to public
# DoH IPs unmodified. Some RU mobile operators DPI-block /443 to
# 1.1.1.1 / 9.9.9.9 outright (observed empirically — `curl` to the
# DoH endpoint times out with no TCP RST). On those networks the
# IP-literal trick is not sufficient by itself, and the proxy stays
# stuck in "bootstrap incomplete" state pre-tunnel. The hotplug DNS
# bootstrap script — configs/hotplug.d/iface/91-awg-dns-bootstrap —
# is what actually closes the loop: it falls dnsmasq back to the
# carrier's DHCP-advertised DNS while AWG is down, then snaps the
# upstream back to DoH once the tunnel comes up. The IP-literal
# resolver_url is still the right config either way (DoH-passing
# operators benefit immediately, DoH-blocking ones are no worse off).
#
# After the tunnel is up, the proxy's outbound TLS to Cloudflare rides
# through awg0 like everything else (since awg0 is the default route).
# That keeps the DoH stream out of the operator's view.
#
# `dnsmasq_config_update '-'` — documented sentinel value that disables
# the package's automatic injection of `list server '127.0.0.1#5053'`
# into /etc/config/dhcp on every start/stop. We need this disabled
# because the dnsmasq upstream is owned by the hotplug script via
# /etc/dnsmasq.d/00-upstream.conf — letting the package also write to
# /etc/config/dhcp produces a two-source-of-truth situation where
# pre-tunnel queries get round-robined between DoH (broken) and the
# carrier DNS (working), making bootstrap unreliable.
#
# Reference: docs.openwrt.melmac.ca/https-dns-proxy/ — "can be set to '-'
# to not change dnsmasq server settings on start/stop". The init script
# tests for '*' (inject everywhere) and is_alnum (inject named instance);
# '-' fails both, so the inject branches are skipped silently.
#
# Common mistake: the option name in older docs / luci-app variants was
# `update_dnsmasq_config`, but the live init script reads
# `dnsmasq_config_update` (note the word order). Using the wrong name
# means the option is ignored and the default '*' applies. Setting both
# is harmless; only the second-word-order key is honored.

config main 'config'
	option dnsmasq_config_update '-'
	option force_dns '0'
	option canary_domains_icloud '1'
	option canary_domains_mozilla '1'

config https-dns-proxy
	option bootstrap_dns '1.1.1.1,1.0.0.1'
	option resolver_url 'https://1.1.1.1/dns-query'
	option listen_addr '127.0.0.1'
	option listen_port '5053'
	option user 'nobody'
	option group 'nogroup'
