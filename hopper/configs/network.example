# Example /etc/config/network for Netcraze Hopper (NC-3811).
# Replace every <PLACEHOLDER> with real values from your AWG .conf and
# your wireless config. Never commit the populated file with private keys.
#
# Architecture:
#   - lan      192.168.1.0/24 on br-lan (lan1+lan2+lan3 switch ports + radio AP)
#   - wan      ethernet uplink (DHCP, metric 10)
#   - wan6     ethernet v6 (DHCPv6, metric 10)
#   - wwan     USB-Eth #1 on eth1 (DHCP, metric 20) — first-enumerated USB modem
#   - wwan2    USB-Eth #2 on eth2 (DHCP, metric 25) — second-enumerated USB modem
#   - awg0     AmneziaWG v2 tunnel (default route, kill switch)
#
# The wwan / wwan2 split is for triple-WAN — typically one is a Huawei
# E3372 HiLink RNDIS and the other is iPhone USB tethering via ipheth.
# Which physical device ends up at eth1 vs eth2 is non-deterministic
# (depends on USB enumeration order). We don't pin by MAC because the
# iPhone randomizes its ipheth MAC per pairing. Both slots are treated
# symmetrically by the split-VPN hotplug — ECMP across whatever is up.
# When only one USB modem is plugged in, wwan2 stays in DOWN state
# (no eth2 device exists) and the dual-WAN topology degrades gracefully
# back to wan + wwan, no config change needed.
#
# AWG obfuscation params use the awg_ prefix on the interface section
# (awg_jc, awg_jmin, awg_jmax, awg_s1..awg_s4, awg_h1..awg_h4, optional
# awg_i1..awg_i5). Without the prefix /lib/netifd/proto/amneziawg.sh
# silently falls back to defaults and the server drops every packet.
#
# IMPORTANT: do NOT set `option mtu '1280'` on the lan section. It causes
# DEVICE_CLAIM_FAILED on br-lan because the wireless ports are 1500 and a
# bridge cannot span mixed MTUs. Announce MTU 1280 to clients via DHCP
# option 26 instead — see configs/dhcp.

config interface 'loopback'
	option device 'lo'
	option proto 'static'
	option ipaddr '127.0.0.1'
	option netmask '255.0.0.0'

config device
	option name 'br-lan'
	option type 'bridge'
	list ports 'lan1'
	list ports 'lan2'
	list ports 'lan3'

config interface 'lan'
	option device 'br-lan'
	option proto 'static'
	option ipaddr '192.168.1.1'
	option netmask '255.255.255.0'

# IPv6 is disabled end-to-end on this router. The AWG provider hands out
# only a /128 on the tunnel and does NOT route IPv6, so a LAN client that
# brought up v6 would blackhole every v6 destination through awg0 and pay
# a happy-eyeballs fallback penalty on every new connection. There is also
# no v6 prefix to delegate, so odhcpd would spam "no public prefix, RA
# lifetime 0" warnings. Rather than run a half-broken v6 stack we remove
# it entirely: no ula_prefix, no ip6assign, no wan6, no v6 on awg0, no
# ::/0 in allowed_ips. See configs/dhcp for the matching ra/dhcpv6 off.

config interface 'wan'
	option device 'wan'
	option proto 'dhcp'
	option metric '10'

# First USB-Ethernet uplink — whichever device enumerates first ends up
# as eth1. Typically the Huawei E3372 HiLink (RNDIS, PID 12d1:14db after
# usb-modeswitch swaps it out of CD-ROM mode 12d1:1f01) but iPhone
# tethering via ipheth also lands here if it's plugged in first.
config interface 'wwan'
	option device 'eth1'
	option proto 'dhcp'
	option metric '20'
	option defaultroute '1'

# Second USB-Ethernet uplink — same DHCP-as-client logic, higher metric.
# Stays DOWN when no second USB-net device is present.
config interface 'wwan2'
	option device 'eth2'
	option proto 'dhcp'
	option metric '25'
	option defaultroute '1'

config interface 'awg0'
	option proto 'amneziawg'
	option private_key '<CLIENT_PRIVATE_KEY>'
	option mtu '1280'
	list addresses '<10.x.x.x/32>'
	# No IPv6 address — v6 is disabled router-wide (see lan section above).
	# AWG v2 obfuscation parameters — copy from your [Interface] section.
	# Values that span ranges (e.g. H1 '168781656-175897653') are passed
	# as-is, the proto handler forwards them to `awg setconf` literally.
	option awg_jc '<JC>'
	option awg_jmin '<JMIN>'
	option awg_jmax '<JMAX>'
	option awg_s1 '<S1>'
	option awg_s2 '<S2>'
	option awg_s3 '<S3>'
	option awg_s4 '<S4>'
	option awg_h1 '<H1>'
	option awg_h2 '<H2>'
	option awg_h3 '<H3>'
	option awg_h4 '<H4>'
	# Uncomment if your .conf has I1..I5
	# option awg_i1 '<I1>'
	# option awg_i2 '<I2>'
	# option awg_i3 '<I3>'
	# option awg_i4 '<I4>'
	# option awg_i5 '<I5>'

config amneziawg_awg0
	option public_key '<SERVER_PUBLIC_KEY>'
	# option preshared_key '<PRESHARED_KEY>'   # if your conf has one
	option endpoint_host '<SERVER_HOSTNAME>'
	option endpoint_port '<SERVER_PORT>'
	option persistent_keepalive '30'
	option route_allowed_ips '1'
	list allowed_ips '0.0.0.0/0'
	# No '::/0' — v6 disabled router-wide; routing it would blackhole.
