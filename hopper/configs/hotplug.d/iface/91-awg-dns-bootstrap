#!/bin/sh
# /etc/hotplug.d/iface/91-awg-dns-bootstrap
#
# Solves the boot-time DNS chicken-and-egg: the AWG endpoint hostname
# needs DNS to resolve, but our trusted DNS path (DoH on 127.0.0.1:5053)
# only works once the AWG tunnel is up.
#
# `option noresolv '1'` in /etc/config/dhcp is the kill switch — we
# explicitly REFUSE to let dnsmasq talk to whatever DNS the carrier
# advertises, because once the tunnel is up that path becomes a leak.
# But pre-tunnel, having no upstream at all means AWG cannot resolve
# its endpoint. Some RU operators DPI-block HTTPS/443 to public DoH
# providers (1.1.1.1, 9.9.9.9, ...) on cellular CGNAT, so the
# IP-literal-DoH workaround is not always enough — when /443 is also
# blocked, there is no DoH path at all until the tunnel comes up.
#
# State machine driven by netifd ifup/ifdown events:
#
#   awg0 ifup   -> wait up to HANDSHAKE_TIMEOUT seconds for an actual
#                  AmneziaWG handshake. If it appears, switch upstream
#                  to DoH (steady state). If not — endpoint UDP is
#                  likely being dropped by the carrier even though
#                  netifd reports the interface as up — keep upstream
#                  in bootstrap mode so DNS still works.
#   awg0 ifdown -> upstream = first DHCP-provided DNS (bootstrap mode)
#   wan/wwan/wwan2 up -> if awg0 is not actually handshaking,
#                        refresh bootstrap with newest DHCP-provided DNS
#   wan/wwan/wwan2 dn -> if awg0 is not actually handshaking, recompute
#                        (other uplink may still be up — pick its DNS)
#
# Why "ifup awg0 != working tunnel": netifd marks an amneziawg interface
# up the moment `awg setconf` succeeds, before the peer has been heard
# from. The peer is the only thing that can confirm the outer UDP path
# is open. Without the handshake check, switching to DoH on a paper-up
# tunnel locks the router into a state where the only resolver
# (127.0.0.1#5053 -> outbound TLS via awg0 -> nowhere) cannot answer
# anything.
#
# Both modes write a single file /etc/dnsmasq.d/00-upstream.conf and
# bounce dnsmasq. The corresponding `list server '127.0.0.1#5053'`
# line MUST be removed from /etc/config/dhcp — the dnsmasq upstream is
# now managed entirely by this hotplug script.
#
# Leak budget: in bootstrap mode the carrier sees the router's own DNS
# queries (most importantly the AWG endpoint A/AAAA lookup). LAN
# clients are unaffected because `lan -> awg` forwarding is the only
# WAN-bound chain in the firewall and AWG is down, so they have no
# path out at all. Once the tunnel comes up the switch back to DoH
# closes the leak. Bootstrap window is bounded by endpoint-resolve +
# AWG handshake (typically 1-3 s).

UPSTREAM_CONF=/etc/dnsmasq.d/00-upstream.conf
DOH_LISTENER='127.0.0.1#5053'
LOG_TAG=dns-bootstrap
HANDSHAKE_TIMEOUT=15   # seconds to wait for first handshake after ifup

case "$INTERFACE" in
	awg0|wan|wan6|wwan|wwan2) ;;
	*) exit 0 ;;
esac

case "$ACTION" in
	ifup|ifdown|ifupdate) ;;
	*) exit 0 ;;
esac

awg_is_up() {
	ifstatus awg0 2>/dev/null \
		| jsonfilter -e '@.up' 2>/dev/null \
		| grep -q '^true$'
}

# A handshake has happened (or is happening) when latest-handshakes is
# non-zero. The kernel module sets this to a UNIX timestamp on the very
# first valid response from the peer, and updates it on every subsequent
# rekey. Zero means: configured but never heard back. We treat zero as
# "tunnel not actually working yet".
awg_handshake_seen() {
	local last
	last=$(awg show awg0 latest-handshakes 2>/dev/null | awk '{print $2}')
	[ -n "$last" ] && [ "$last" != "0" ]
}

# Poll for first handshake. Returns 0 if seen within HANDSHAKE_TIMEOUT
# seconds, 1 otherwise.
wait_for_handshake() {
	local i=0
	while [ "$i" -lt "$HANDSHAKE_TIMEOUT" ]; do
		awg_handshake_seen && return 0
		sleep 1
		i=$((i + 1))
	done
	return 1
}

# First plain-DNS server from any currently-up DHCP uplink. netifd
# rewrites /tmp/resolv.conf.d/resolv.conf.auto on every iface change,
# so reading it here always reflects the live set of upstreams.
first_dhcp_dns() {
	[ -r /tmp/resolv.conf.d/resolv.conf.auto ] || return 1
	awk '/^nameserver / && $2 ~ /^[0-9.]+$/ && $2 != "127.0.0.1" {
		print $2; exit
	}' /tmp/resolv.conf.d/resolv.conf.auto
}

# Write content to UPSTREAM_CONF and return 0 if it changed. Skipping
# the restart on a no-op write avoids flapping dnsmasq during
# unrelated ifupdate events.
write_conf() {
	local new="$1"
	local cur=
	[ -r "$UPSTREAM_CONF" ] && cur=$(cat "$UPSTREAM_CONF")
	[ "$cur" = "$new" ] && return 1
	printf '%s\n' "$new" > "$UPSTREAM_CONF"
	return 0
}

apply_doh_mode() {
	local new
	new=$(cat <<EOF
# Managed by /etc/hotplug.d/iface/91-awg-dns-bootstrap.
# AWG tunnel is up — route DNS exclusively through DoH.
server=$DOH_LISTENER
EOF
)
	if write_conf "$new"; then
		logger -t "$LOG_TAG" "tunnel up: dnsmasq upstream -> DoH ($DOH_LISTENER)"
		/etc/init.d/dnsmasq restart >/dev/null 2>&1
	fi
}

apply_bootstrap_mode() {
	local dns new
	dns=$(first_dhcp_dns)
	if [ -z "$dns" ]; then
		# No uplink with DHCP DNS yet. Leave DoH as the placeholder so
		# dnsmasq has something to start against; this entry will be
		# replaced the moment any uplink finishes DHCP.
		new=$(cat <<EOF
# Managed by /etc/hotplug.d/iface/91-awg-dns-bootstrap.
# AWG down, no uplink DNS yet — placeholder (will fail until an
# uplink fires its own ifup and re-runs this script).
server=$DOH_LISTENER
EOF
)
		if write_conf "$new"; then
			logger -t "$LOG_TAG" "tunnel down, no uplink DNS: placeholder upstream"
			/etc/init.d/dnsmasq restart >/dev/null 2>&1
		fi
		return
	fi
	new=$(cat <<EOF
# Managed by /etc/hotplug.d/iface/91-awg-dns-bootstrap.
# AWG tunnel is down — bootstrap via the first DHCP-provided DNS so
# the AWG endpoint hostname can resolve. Reverts to DoH on awg0 ifup.
server=$dns
EOF
)
	if write_conf "$new"; then
		logger -t "$LOG_TAG" "tunnel down: dnsmasq upstream -> DHCP DNS ($dns)"
		/etc/init.d/dnsmasq restart >/dev/null 2>&1
	fi
}

if [ "$INTERFACE" = "awg0" ]; then
	case "$ACTION" in
		ifup)
			# Optimistically install bootstrap mode FIRST so DNS keeps
			# working during the handshake wait. If we sat in DoH mode
			# from a previous tunnel-up cycle and the new ifup never
			# completes a handshake (carrier DPI'd the endpoint), DNS
			# would otherwise be dead for the entire timeout. After
			# the handshake actually completes, upgrade to DoH.
			apply_bootstrap_mode
			if wait_for_handshake; then
				apply_doh_mode
			else
				logger -t "$LOG_TAG" "awg0 ifup: no handshake in ${HANDSHAKE_TIMEOUT}s, staying in bootstrap"
			fi
			;;
		ifdown)
			apply_bootstrap_mode
			;;
	esac
else
	# wan / wan6 / wwan / wwan2 event — only matters while the tunnel
	# is not actually working (handshake-level "up", not netifd-level).
	awg_handshake_seen || apply_bootstrap_mode
fi
