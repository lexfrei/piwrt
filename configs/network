# Example /etc/config/network
# Replace every <PLACEHOLDER> with real values from your AWG .conf.
# Never commit the populated file with private keys.
#
# AWG v2 obfuscation parameters use the 'awg_' prefix on the interface
# section (awg_jc, awg_jmin, awg_jmax, awg_s1..awg_s4, awg_h1..awg_h4,
# awg_i1..awg_i5). Without the prefix, /lib/netifd/proto/amneziawg.sh
# silently falls back to defaults and the server will drop every packet.
#
# IMPORTANT: do NOT set `option mtu '1280'` on the lan section. It causes
# DEVICE_CLAIM_FAILED on br-lan because wireless port phy0-ap0 is 1500
# and a bridge cannot span mixed MTUs. Announce MTU 1280 to clients via
# DHCP option 26 instead — see configs/dhcp.

config interface 'loopback'
    option device 'lo'
    option proto 'static'
    option ipaddr '127.0.0.1'
    option netmask '255.0.0.0'

config globals 'globals'
    option ula_prefix 'fd00:abcd:1234::/48'

config device
    option name 'br-lan'
    option type 'bridge'
    # eth0 is NOT listed — it is the WAN uplink.
    # Wireless phy0-ap0 attaches via `option network 'lan'` in /etc/config/wireless.

config interface 'lan'
    option device 'br-lan'
    option proto 'static'
    option ipaddr '192.168.1.1'
    option netmask '255.255.255.0'
    option ip6assign '60'

config interface 'wan'
    option device 'eth0'
    option proto 'dhcp'
    # metric is used by split-vpn-init.sh to pick the primary uplink
    # when multiple WAN-family interfaces are up. Lower wins.
    option metric '10'

config interface 'wan6'
    option device 'eth0'
    option proto 'dhcpv6'
    option metric '10'

# Optional: USB Wi-Fi dongle (mt76) in STA mode as LTE/hotspot fallback.
# Uncomment once the radio is wired up in /etc/config/wireless and added
# to firewall zone `wan` (see configs/firewall).
#
# config interface 'wwan'
#     option proto 'dhcp'
#     option metric '20'

config interface 'awg0'
    option proto 'amneziawg'
    option private_key '<CLIENT_PRIVATE_KEY>'
    option mtu '1280'
    list addresses '<10.x.x.x/32>'
    list addresses '<IPV6_ADDRESS/128>'
    # AWG v2 obfuscation parameters — copy from your [Interface] section.
    option awg_jc '<JC>'
    option awg_jmin '<JMIN>'
    option awg_jmax '<JMAX>'
    option awg_s1 '<S1>'
    option awg_s2 '<S2>'
    option awg_s3 '<S3>'
    option awg_s4 '<S4>'
    option awg_h1 '<H1>'
    option awg_h2 '<H2>'
    option awg_h3 '<H3>'
    option awg_h4 '<H4>'
    # option awg_i1 '<I1>'   # uncomment if your .conf has I1..I5
    # option awg_i2 '<I2>'
    # option awg_i3 '<I3>'
    # option awg_i4 '<I4>'
    # option awg_i5 '<I5>'

config amneziawg_awg0
    option public_key '<SERVER_PUBLIC_KEY>'
    # option preshared_key '<PRESHARED_KEY>'   # if your conf has one
    option endpoint_host '<SERVER_HOSTNAME_OR_IP>'
    option endpoint_port '<SERVER_PORT>'
    option persistent_keepalive '30'
    option route_allowed_ips '1'
    list allowed_ips '0.0.0.0/0'
    list allowed_ips '::/0'
